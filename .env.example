# Copy to .env and fill in your values before running locally.
# Never commit .env to git.

ANTHROPIC_API_KEY=sk-ant-...
FMP_API_KEY=your_fmp_api_key
FRED_API_KEY=your_fred_api_key

# AWS credentials (use ~/.aws/credentials or IAM role in Lambda)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# LangSmith tracing (optional — enables agent observability)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls-...
LANGCHAIN_PROJECT=alpha-research

# Email
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Data sources
EDGAR_IDENTITY=your-email@example.com
GITHUB_TOKEN=github_pat_...

# S3 bucket name
S3_BUCKET=alpha-engine-research

# RAG (optional — vector search over SEC filings + earnings transcripts)
RAG_DATABASE_URL=postgresql://...
VOYAGE_API_KEY=pa-...
